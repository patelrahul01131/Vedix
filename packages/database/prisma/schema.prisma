generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("USER") // 'USER', 'ADMIN'
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  apiKeys      ApiKey[]
  missions     Mission[]
  memories     Memory[]
  agentMemories AgentMemory[]
  memoryExtractionQueues MemoryExtractionQueue[]
  explicitPreferences    UserExplicitPreference[]
  
  // Web App Relations
  webMissions    WebMission[]
  webSettings    WebUserSettings?
  analyticsLogs  WebAnalyticsLog[]
  oauthConnections OAuthConnection[]
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  name      String    @default("Default Key")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime? // Null means never expires
}

model Mission {
  id            String    @id @default(uuid())
  userId        String?   // Optional temporarily for backward compatibility
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  title         String
  status        String    @default("Idle")
  workingMemory String    @default("")
  summary       String?   // Rolling summary of older messages
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]
}

model Message {
  id          String   @id @default(uuid())
  parentId    String?
  role        String   // 'user', 'assistant', 'tool', 'system'
  content     String?  
  toolCalls   String?  // JSON stringified array of tool calls
  toolResults String?  // JSON stringified array of tool results
  sources     String?  // JSON stringified array of sources
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([missionId, createdAt])
}

model Memory {
  id        String   @id @default(uuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentMemory {
  id          String   @id @default(uuid())
  userId      String   
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isGlobal    Boolean  @default(false)
  type        String   // 'SKILL', 'ERROR', 'PREFERENCE', 'RULE', 'BEHAVIOR', 'PROFILE'
  content     String   // The extracted memory text
  confidence  Int      @default(50) // Score from 0 to 100 for memory decay
  status      String   @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  embedding   Json?    // Stores embedding as float array for local Node.js RAG
  embeddingVector Unsupported("vector(2048)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TokenLog {
  id          String   @id @default(uuid())
  modelName   String
  service     String   // e.g. "Planner", "MemoryExtractor", "MemoryCritic"
  promptTokens Int     @default(0)
  completionTokens Int @default(0)
  totalTokens Int      @default(0)
  
  messageId   String?  // Links the token usage to a specific chat message
  missionId   String?  // Links the token usage to a specific mission

  createdAt   DateTime @default(now())
}

model AgentState {
  id        String   @id @default("global_state")
  status    String   @default("Offline")
  updatedAt DateTime @updatedAt
}

// --- WEB APP MODELS ---

model WebMission {
  id            String       @id @default(uuid())
  userId        String?   
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  title         String
  status        String       @default("Idle")
  summary       String?      
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  messages      WebMessage[]
}

model WebMessage {
  id          String     @id @default(uuid())
  role        String     // 'user', 'assistant', 'tool', 'system'
  content     String?  
  missionId   String
  mission     WebMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([missionId, createdAt])
}

model WebUserSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  temperature     Float    @default(0.72)
  topP            Float    @default(0.95)
  webSearch       Boolean  @default(true)
  codeInterpreter Boolean  @default(true)
  thirdParty      Boolean  @default(false)
  gmailEnabled    Boolean  @default(false)
  canvaEnabled    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WebAnalyticsLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  modelName   String
  status      String   @default("SUCCESS") // 'SUCCESS', 'ERROR'
  latencyMs   Int      @default(0)
  tokens      Int      @default(0)
  cost        Float    @default(0.0)
  createdAt   DateTime @default(now())
}

model OAuthConnection {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // e.g., 'google', 'canva', 'notion'
  providerId   String   // the user's ID on that provider
  email        String?  // the email associated with the 3rd party account
  
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, provider]) // one connection per provider per user
}

// --- UNIFIED ASYNC MEMORY PIPELINE ---

model MemoryExtractionQueue {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  userMessage     String   @db.Text
  agentResponse   String   @db.Text
  source          String   // e.g., 'WEB', 'EXTENSION'
  
  status          String   @default("PENDING") // 'PENDING', 'PROCESSING', 'COMPLETED'
  attempts        Int      @default(0)
  
  createdAt       DateTime @default(now())
  
  @@index([status, createdAt])
}

model UserExplicitPreference {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String   
  rule        String   @db.Text 
  source      String   // 'WEB' or 'EXTENSION'
  isActive    Boolean  @default(true)
  
  confidence  Int      @default(50)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, category])
}
