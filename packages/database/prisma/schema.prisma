generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("USER") // 'USER', 'ADMIN'
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  apiKeys      ApiKey[]
  missions     Mission[]
  memories     Memory[]
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  name      String    @default("Default Key")
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime? // Null means never expires
}

model Mission {
  id            String    @id @default(uuid())
  userId        String?   // Optional temporarily for backward compatibility
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  title         String
  status        String    @default("Idle")
  workingMemory String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]
}

model Message {
  id          String   @id @default(uuid())
  parentId    String?
  role        String   // 'user', 'assistant', 'tool', 'system'
  content     String?  
  toolCalls   String?  // JSON stringified array of tool calls
  toolResults String?  // JSON stringified array of tool results
  sources     String?  // JSON stringified array of sources
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Memory {
  id        String   @id @default(uuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentState {
  id        String   @id @default("global_state")
  status    String   @default("Offline")
  updatedAt DateTime @updatedAt
}
