# Dependency directories
node_modules/

# Build outputs
dist/
out/
build/
.turbo/

# Environment variables — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Also cover all nested service .env files
**/.env
**/.env.local
**/.env.*.local
# Keep example templates
!.env.example
!**/.env.example

# Database/Data storage
.lancedb/
*.db
*.sqlite

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VS Code Extension testing
.vscode-test/
*.vsix

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz
